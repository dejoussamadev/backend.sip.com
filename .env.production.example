# Copy this file to .env.production and fill in real values before running:
#   make dciup-prod
# This file is an example only — do NOT put real secrets here.

# Database Configuration
# DATABASE_URL is assembled by docker-compose.production.yml from the
# compose-level .env (see .infra/compose/.env.example) — do NOT set it here.
# The compose `environment:` block overrides any value in this file.

# Application
NODE_ENV=production
PORT=3000
# In prod the browser hits nginx on the client container at the VM's public
# URL, so client and api share one origin and CORS usually isn't even
# consulted. Keep this set to the public URL as a defense-in-depth /
# direct-API-access allowlist (comma-separated for multiple origins).
CORS_ORIGINS=http://4.251.192.118

# Auth
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRATION=1d
# Cookie security attributes. Defaults are safe for HTTP-only prod (single
# origin via nginx). Flip COOKIE_SECURE to `true` once TLS is in place.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Third-party
PEXELS_API_KEY=CHANGE_ME

UID=1000
GID=1000
