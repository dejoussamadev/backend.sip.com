enum ReservationIdType {
  ID
  PASSPORT
}

enum ContractPeriod {
  FIVE_MONTHS_OR_BELOW
  SIX_MONTHS
  TWELVE_MONTHS
  THIRTEEN_MONTHS
  FOURTEEN_MONTHS
  FIFTEEN_MONTHS
  TWENTY_FOUR_MONTHS
}

enum PaymentModality {
  INSTALLMENT_OFF_PLAN
  MORTGAGE
  CASH_PAYMENT
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
}

enum ReservationStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
}

enum PaymentMode {
  FULL
  PARTIAL
}

model Reservation {
  id                     Int                   @id @default(autoincrement())
  reservationDate        DateTime
  firstName              String
  lastName               String
  nationality            String
  idType                 ReservationIdType
  idNumber               String
  email                  String
  phone                  String
  countryCode            String

  propertyId             Int
  property               Property              @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  unitNumber             String?

  contractPeriod         ContractPeriod
  paymentModality        PaymentModality?
  moveInDate             DateTime?
  contractStartDate      DateTime

  sellingPrice           Decimal               @db.Decimal(15, 2)
  downPaymentPct         Decimal?              @db.Decimal(5, 2)
  commissionPct          Decimal?              @db.Decimal(5, 2)
  reservationFeeAmount   Decimal               @db.Decimal(15, 2)
  paymentMode            PaymentMode?
  paymentAmount          Decimal?              @db.Decimal(15, 2)

  paymentMethod          PaymentMethod
  paymentProofUrl        String?

  consultantId           Int
  consultant             User                  @relation("ReservationConsultant", fields: [consultantId], references: [id], onDelete: Restrict)

  clientSignatureUrl     String
  consultantSignatureUrl String

  termsAcceptedAt        DateTime

  status                 ReservationStatus     @default(PENDING_APPROVAL)
  rejectionReason        String?
  approvedById           Int?
  approvedBy             User?                 @relation("ReservationApprover", fields: [approvedById], references: [id])
  approvedAt             DateTime?

  createdById            Int
  createdBy              User                  @relation("ReservationCreator", fields: [createdById], references: [id], onDelete: Restrict)

  linkId                 Int?                  @unique
  link                   ReservationLink?      @relation(fields: [linkId], references: [id])

  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([propertyId])
  @@index([createdById])
  @@index([consultantId])
  @@index([contractPeriod])
  @@index([status])
  @@map("reservations")
}

model ReservationLink {
  id                     Int          @id @default(autoincrement())
  code                   String       @unique @db.VarChar(16)
  propertyId             Int
  property               Property     @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  generatedById          Int
  generatedBy            User         @relation("ReservationLinksCreated", fields: [generatedById], references: [id], onDelete: Restrict)
  unitNumber             String?
  commissionPct          Decimal?     @db.Decimal(5, 2)
  downPaymentPct         Decimal?     @db.Decimal(5, 2)
  reservationFeePct      Decimal?     @db.Decimal(5, 2)
  consultantSignatureUrl String
  expiresAt              DateTime
  consumedAt             DateTime?
  reservation            Reservation?
  createdAt              DateTime     @default(now())

  @@index([propertyId])
  @@map("reservation_links")
}
