enum CategoryKind {
  SALE
  RENT
}

model Category {
  id   Int          @id @default(autoincrement())
  name String       @unique
  /// Drives sale-vs-rent business rules (reservation fees, payment modes, UI badges).
  /// Locked at creation — admins can rename the category but not change its kind.
  kind CategoryKind

  properties  Property[]
  furnishings CategoryFurnishing[]
  types       CategoryType[]

  @@map("categories")
}

model CategoryFurnishing {
  categoryId   Int
  furnishingId Int

  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  furnishing Furnishing @relation(fields: [furnishingId], references: [id], onDelete: Cascade)

  @@id([categoryId, furnishingId])
  @@map("category_furnishings")
}

model CategoryType {
  categoryId Int
  typeId     Int

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  type     Type     @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@id([categoryId, typeId])
  @@map("category_types")
}
