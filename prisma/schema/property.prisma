enum PropertyStatus {
  AVAILABLE
  PENDING
  NOT_AVAILABLE
  ON_HOLD
  UPCOMING
  ARCHIVED
  TRASH
  REJECTED
}

enum PropertyAccess {
  CALL_APPOINTMENT
  DIRECT_APPOINTMENT
  EMAIL_APPOINTMENT
}

enum PropertyView {
  BEACH
  CITY
  COMMUNITY
  FACILITIES
  FULL_SEA
  MARINA
  MIXED
  PARTIAL_MARINA
  PARTIAL_SEA
}

model Property {
  id              Int             @id @default(autoincrement())
  referenceNumber String          @unique
  name            String
  shortTerm       Boolean         @default(false)
  unitNumber      String?
  bathrooms       Int
  size            Float
  maidRoom        Boolean
  balcony         String          @default("")
  view            PropertyView?
  range           Float
  commission      Float
  status          PropertyStatus  @default(PENDING)
  expirationDate  DateTime
  access          PropertyAccess?
  hasUtilities    Boolean         @default(false)
  hasFacilities   Boolean         @default(false)
  details         String
  directions      String
  images          String[]
  document        String?

  // Relations
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  typeId Int
  type   Type @relation(fields: [typeId], references: [id])

  layoutId Int
  layout   Layout @relation(fields: [layoutId], references: [id])

  locationId Int
  location   Location @relation(fields: [locationId], references: [id])

  furnishingId Int
  furnishing   Furnishing @relation(fields: [furnishingId], references: [id])

  landlordId Int
  landlord   Landlord @relation(fields: [landlordId], references: [id])

  agentId Int
  agent   Agent @relation(fields: [agentId], references: [id])

  utilities  PropertyUtility[]
  facilities PropertyFacility[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([typeId])
  @@index([layoutId])
  @@index([locationId])
  @@index([agentId])
  @@map("properties")
}
