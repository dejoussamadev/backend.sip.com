generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  AGENT
  ADMIN
}

enum PropertyStatus {
  DRAFT
  ACTIVE
  SOLD
  RENTED
  EXPIRED
}

model Agent {
  id                  Int      @id @default(autoincrement())
  name                String
  agentCode           String   @unique
  email               String   @unique
  password            String
  mobile              String
  countryCode         String   @default("+974")
  designation         String?
  photo               String?
  bookmarkLimit       Int      @default(50)
  onlinePropertyLimit Int      @default(0)
  role                Role     @default(AGENT)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  properties Property[]

  @@map("agents")
}

model Property {
  id              Int            @id @default(autoincrement())
  referenceNumber String         @unique
  name            String
  shortTerm       Boolean        @default(false)
  unitNumber      String?
  bathrooms       Int
  size            Float
  maidRoom        Boolean
  balcony         String         @default("")
  view            String         @default("")
  range           Float
  commission      Float
  status          PropertyStatus @default(DRAFT)
  expirationDate  DateTime
  access          String         @default("")
  hasUtilities    Boolean        @default(false)
  hasFacilities   Boolean        @default(false)
  details         String
  directions      String
  images          String[]
  document        String?

  // Relations
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  typeId Int?
  type   Type? @relation(fields: [typeId], references: [id])

  layoutId Int?
  layout   Layout? @relation(fields: [layoutId], references: [id])

  locationId Int?
  location   Location? @relation(fields: [locationId], references: [id])

  furnishingId Int?
  furnishing   Furnishing? @relation(fields: [furnishingId], references: [id])

  landlordId Int?
  landlord   Landlord? @relation(fields: [landlordId], references: [id])

  agentId Int?
  agent   Agent? @relation(fields: [agentId], references: [id])

  utilities  PropertyUtility[]
  facilities PropertyFacility[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([typeId])
  @@index([layoutId])
  @@index([locationId])
  @@index([agentId])
  @@map("properties")
}

model Utility {
  id         Int               @id @default(autoincrement())
  name       String            @unique
  properties PropertyUtility[]

  @@map("utilities")
}

model PropertyUtility {
  propertyId Int
  utilityId  Int

  property Property @relation(fields: [propertyId], references: [id])
  utility  Utility  @relation(fields: [utilityId], references: [id])

  @@id([propertyId, utilityId])
  @@map("property_utilities")
}

model Facility {
  id         Int                @id @default(autoincrement())
  name       String             @unique
  properties PropertyFacility[]

  @@map("facilities")
}

model PropertyFacility {
  propertyId Int
  facilityId Int

  property Property @relation(fields: [propertyId], references: [id])
  facility Facility @relation(fields: [facilityId], references: [id])

  @@id([propertyId, facilityId])
  @@map("property_facilities")
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique

  properties Property[]

  furnishings CategoryFurnishing[]
  types       CategoryType[]

  @@map("categories")
}

model Type {
  id   Int    @id @default(autoincrement())
  name String @unique

  categories CategoryType[]
  layouts    TypeLayout[]
  properties Property[]

  @@map("types")
}

model Layout {
  id   Int    @id @default(autoincrement())
  name String @unique

  types      TypeLayout[]
  properties Property[]

  @@map("layouts")
}

model Location {
  id        Int    @id @default(autoincrement())
  name      String @unique
  longitude Float
  latitude  Float

  properties Property[]

  @@map("locations")
}

model Landlord {
  id                 Int     @id @default(autoincrement())
  name               String
  email              String
  mobile             String
  alternativeMobile  String?
  note               String?
  mapLink            String?
  marketingAgreement Boolean @default(false)
  draftContract      Boolean @default(false)

  properties Property[]

  @@map("landlords")
}

model Furnishing {
  id   Int    @id @default(autoincrement())
  name String @unique

  categories CategoryFurnishing[]
  properties Property[]

  @@map("furnishings")
}

model CategoryFurnishing {
  categoryId   Int
  furnishingId Int

  category   Category   @relation(fields: [categoryId], references: [id])
  furnishing Furnishing @relation(fields: [furnishingId], references: [id])

  @@id([categoryId, furnishingId])
  @@map("category_furnishings")
}

model CategoryType {
  categoryId Int
  typeId     Int

  category Category @relation(fields: [categoryId], references: [id])
  type     Type     @relation(fields: [typeId], references: [id])

  @@id([categoryId, typeId])
  @@map("category_types")
}

model TypeLayout {
  typeId   Int
  layoutId Int

  type   Type   @relation(fields: [typeId], references: [id])
  layout Layout @relation(fields: [layoutId], references: [id])

  @@id([typeId, layoutId])
  @@map("type_layouts")
}
