# deps / build output
node_modules
dist

# secrets — never bake into an image layer
.env
.env.*
!.env.exemple
!.env.production.example

# vcs / editor / logs
.git
.gitignore
.idea
.vscode
*.log

# test artifacts
coverage
.nyc_output

